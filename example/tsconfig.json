{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["../src/*"],
      "@cored-im/openapi-sdk": ["../src/index.ts"],
      "@cored-im/openapi-sdk/*": ["../src/*"]
    }
  },
  "include": ["./**/*"]
}
